        <mxCell id="TvCFzuCl8OrDGds0ZS7_-32" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;verticalAlign=top;fontSize=11;size=20;" value="&lt;b&gt;🔴 TIPOS DE ATAQUE&lt;/b&gt;&lt;br&gt;&lt;br&gt;1. Envenenamento de Dados:&lt;br&gt;   - Inversão de labels (30%)&lt;br&gt;   - Adição de ruído nas features&lt;br&gt;   - Modificação sistemática de valores&lt;br&gt;&lt;br&gt;2. Envenenamento de Modelo:&lt;br&gt;   - Adição de ruído gaussiano aos pesos&lt;br&gt;   - Inversão de sinais dos pesos&lt;br&gt;   - Amplificação de gradientes" vertex="1">
          <mxGeometry height="220" width="280" x="800" y="470" as="geometry" />
        </mxCell>
        <mxCell id="TvCFzuCl8OrDGds0ZS7_-33" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;verticalAlign=top;fontSize=11;size=20;" value="&lt;b&gt;📊 AGREGAÇÃO PONDERADA&lt;/b&gt;&lt;br&gt;&lt;br&gt;Peso de cada cliente calculado como:&lt;br&gt;&lt;br&gt;peso_i = acuracia_i / Σ(acurácias)&lt;br&gt;&lt;br&gt;Clientes com melhor desempenho&lt;br&gt;têm maior influência no modelo global." vertex="1">
          <mxGeometry height="160" width="280" x="800" y="730" as="geometry" />
        </mxCell>
        <mxCell id="TvCFzuCl8OrDGds0ZS7_-34" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;fontSize=11;size=20;" value="&lt;b&gt;✓ CONVERGÊNCIA&lt;/b&gt;&lt;br&gt;&lt;br&gt;Critério de convergência:&lt;br&gt;|acuracia_atual - acuracia_anterior| &amp;lt; ε&lt;br&gt;&lt;br&gt;Avalia estabilização das métricas&lt;br&gt;entre rodadas consecutivas." vertex="1">
          <mxGeometry height="160" width="240" x="1120" y="470" as="geometry" />
        </mxCell>
        <mxCell id="TvCFzuCl8OrDGds0ZS7_-35" parent="1" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;align=center;" value="&lt;h1&gt;Sistema de Aprendizado Federado com Ataques de Envenenamento&lt;/h1&gt;&lt;p&gt;Diagrama UML - Classes, Atributos, Métodos e Relacionamentos&lt;/p&gt;" vertex="1">
